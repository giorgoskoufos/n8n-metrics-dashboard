# Server Config
DASHBOARD_PORT=3000
DASHBOARD_JWT_SECRET='your_secure_random_secret_here'

# Database Config (Connection to your n8n PostgreSQL)
DASHBOARD_DB_USER=postgres
DASHBOARD_DB_HOST=127.0.0.1
DASHBOARD_DB_NAME=n8n_data
DASHBOARD_DB_PASS=your_db_password
DASHBOARD_DB_PORT=5432

# Alternative Database Config (Direct URL)
#DASHBOARD_DATABASE_URL=postgres://user:pass@host:port/n8n_data?sslmode=disable

# n8n Editor Integration (for deep-linking errors in the UI)
N8N_EDITOR_BASE_URL=https://your-n8n-instance.com

# AI Chat Subsystem
OPENAI_API_KEY=sk-proj-your-key-here

# Background ETL Sync Frequency (in minutes, Optional, Defaults to 5)
SYNC_INTERVAL_MINUTES=5
